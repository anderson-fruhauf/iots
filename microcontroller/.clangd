# IntelliSense (clangd): usa o compile_commands.json do PlatformIO.
# Regenerar após mudar libs/flags: pio run -t compiledb
# --query-driver no .vscode/settings.json permite ao clangd consultar o xtensa-g++
# e achar newlib (ex.: machine/endian.h). BuiltinHeaders: QueryDriver usa esses includes.
---
# O compiledb do PlatformIO costuma omitir -I das libs; sem isso o clangd não acha headers do framework / lib_deps.
CompileFlags:
  CompilationDatabase: .
  BuiltinHeaders: QueryDriver
  # -I e caminho separados; caminhos com "~" entre aspas (YAML 1.1: ~ sozinho = null).
  Add:
    - -I
    - '~/.platformio/packages/framework-arduinoespressif32/libraries/WiFi/src'
    - -I
    - '~/.platformio/packages/framework-arduinoespressif32/libraries/Ticker/src'
    - -I
    - .pio/libdeps/esp32doit-devkit-v1/PubSubClient/src
    - -I
    - .pio/libdeps/esp32doit-devkit-v1/DHT sensor library for ESPx
  Remove:
    - -mfix-esp32-psram-cache-issue
    - -mfix-esp32-psram-cache-strategy=memw
    - -mlongcalls
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-jump-tables
